{
  "name": "@tuyen-at-work/x-pkg",
  "version": "0.0.15",
  "type": "module",
  "bin": {
    "x-pkg": "./bin/cli.js"
  },
  "scripts": {
    "prestart": "bun upgrade",
    "start": "bun run dev",
    "serve": "bun run dev",
    "dev": "concurrently --kill-others \"bun xpack/styles.ts --watch\" \"bun xpack/states.ts --watch\" \"cross-env scriptOnly=true vite build --mode development --watch\" \"bun xpack/server.ts --mode development\"",
    "watch": "bun xpack/server.ts",
    "build": "bun run build:static && bun run build:server",
    "build:eshn": "bun run build:static:eshn && bun run build:server:eshn",
    "build:server": "vite build --ssr xpack/entry-server.tsx --outDir dist/server",
    "build:server:eshn": "vite build --ssr xpack/entry-server.tsx --outDir dist/server --mode eshn",
    "build:static": "vite build --outDir dist/static",
    "build:static:eshn": "vite build --outDir dist/static --mode eshn",
    "generate": "bun xpack/states.ts && bun run styles && bun run build && bun xpack/prerender.ts --add-hash",
    "eshn": "bun xpack/states.ts && bun run styles && bun run build:eshn && bun xpack/prerender.ts --add-hash --mode eshn",
    "inte": "bun run styles && bun run build && bun xpack/prerender.ts && bun xpack/integration.ts",
    "styles": "bun xpack/styles.ts",
    "lint": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "bun run typecheck && vitest run --coverage --reporter=default",
    "xpack:styles": "xpack styles",
    "xpack:scripts": "xpack scripts",
    "xpack:dev": "xpack dev",
    "xpack:build": "xpack build",
    "xpack:prerender": "xpack prerender",
    "xpack:integrate": "xpack integrate",
    "xpack:states": "xpack states",
    "xpack:generate": "xpack generate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@quanvu-optimizely/xpack": "file:../PreciseAlloy.xPack",
    "@types/js-yaml": "^4.0.9",
    "chalk": "^5.5.0",
    "express-rate-limit": "^8.4.1",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/css": "^0.0.38",
    "@types/debounce": "^1.2.4",
    "@types/express": "^5.0.6",
    "@types/js-beautify": "^1.14.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.11.0",
    "@types/prettier": "^2.7.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.27",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "css": "^3.0.0",
    "cssnano": "^7.1.0",
    "debounce": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "js-beautify": "^1.15.4",
    "jsdom": "^29.1.0",
    "lodash": "^4.17.21",
    "magic-string": "^0.30.17",
    "msw": "^2.13.6",
    "postcss": "^8.5.12",
    "prettier": "^3.6.2",
    "rollup": "^4.59.0",
    "sass": "^1.89.2",
    "slash": "^5.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "msw": {
    "workerDirectory": "public"
  }
}